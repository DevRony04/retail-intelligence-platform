# =========================================================================
# Apex Retail - Store Intelligence System Configuration (.env.example)
# =========================================================================
# Apex Retail - Store Intelligence System Configuration (.env.example)
# =========================================================================
# Copy this file to '.env' and edit the values to match your environment.
# Never commit real secrets or production credentials.

# -------------------------------------------------------------------------
# Application Environment
# -------------------------------------------------------------------------

APP_ENV=development
DEBUG=true

# -------------------------------------------------------------------------
# Database Configuration (PostgreSQL-First)
# -------------------------------------------------------------------------
# PostgreSQL Connection URL format:
# postgresql://<username>:<password>@<host>:<port>/<db_name>

DATABASE_URL=postgresql://postgres:Password123@localhost:5432/store_intelligence

# SQLite fallback configuration (optional local fallback)
# DATABASE_URL=sqlite:///./store_intelligence.db

# -------------------------------------------------------------------------
# Database Pool Configuration
# -------------------------------------------------------------------------

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# -------------------------------------------------------------------------
# FastAPI Server Configuration
# -------------------------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8000

# -------------------------------------------------------------------------
# Streamlit & Ingestion Pipeline Configuration
# -------------------------------------------------------------------------

API_URL=http://localhost:8000
STREAMLIT_PORT=8501

# -------------------------------------------------------------------------
# Detection Pipeline Configuration
# -------------------------------------------------------------------------

CONFIDENCE_THRESHOLD=0.4
DWELL_THRESHOLD_SECONDS=30

ENABLE_REENTRY_DETECTION=true
ENABLE_QUEUE_ANALYTICS=true
ENABLE_HEATMAP_ANALYTICS=true

# -------------------------------------------------------------------------
# Model Configuration
# -------------------------------------------------------------------------

YOLO_MODEL=yolov8n.pt
TRACKER_TYPE=bytetrack

# -------------------------------------------------------------------------
# File & Output Paths
# -------------------------------------------------------------------------

VIDEO_DATA_PATH=./data
EVENT_OUTPUT_PATH=./outputs/events.jsonl
LOG_OUTPUT_PATH=./outputs/logs

# -------------------------------------------------------------------------
# Logging Configuration
# -------------------------------------------------------------------------

LOG_LEVEL=INFO